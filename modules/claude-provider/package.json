{
  "name": "@codex-modules/claude-provider",
  "version": "0.1.0",
  "description": "Personal localhost provider adapter for Codex custom providers backed by Claude.",
  "keywords": [
    "codex",
    "openai-codex",
    "claude",
    "provider",
    "adapter"
  ],
  "license": "MIT",
  "author": "ArcSolver <hailo.dev01@gmail.com>",
  "homepage": "https://github.com/ArcSolver/codex-modules/tree/main/modules/claude-provider#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArcSolver/codex-modules.git",
    "directory": "modules/claude-provider"
  },
  "bugs": "https://github.com/ArcSolver/codex-modules/issues",
  "type": "module",
  "bin": {
    "codex-claude-provider": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.ko.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "verify": "bash verify/verify.sh",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.202",
    "@anthropic-ai/sdk": "0.110.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  }
}

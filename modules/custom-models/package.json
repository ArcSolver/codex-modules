{
  "name": "@codex-modules/custom-models",
  "version": "0.1.0",
  "description": "Register Responses-API-compatible custom models in the official Codex model picker.",
  "keywords": [
    "codex",
    "openai-codex",
    "codex-cli",
    "custom-models",
    "model-catalog",
    "model-picker"
  ],
  "license": "MIT",
  "author": "ArcSolver <hailo.dev01@gmail.com>",
  "homepage": "https://github.com/ArcSolver/codex-modules/tree/main/modules/custom-models#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArcSolver/codex-modules.git",
    "directory": "modules/custom-models"
  },
  "bugs": "https://github.com/ArcSolver/codex-modules/issues",
  "type": "module",
  "bin": {
    "codex-custom-models": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "verify": "bash verify/verify.sh",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.9.0"
  }
}
